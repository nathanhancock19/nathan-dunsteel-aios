# Auth.js v5 (NextAuth)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
AUTH_SECRET=

# AIOS single-user credentials.
# Generate the hash with:
#   node scripts/hash-password.mjs "<your password>"
# The script outputs the hash with $ characters already escaped as \$, which
# is required for Next.js's dotenv-expand parser. Paste the output verbatim.
AIOS_USER_USERNAME=nathan
AIOS_USER_PASSWORD_HASH=

# Module link-out URLs
DAY_DOCKET_APP_URL=https://dunsteel-docket-app.vercel.app
SWMS_TALLY_URL=https://tally.so/r/0QdBdZ
NOTION_SITE_DIARY_URL=

