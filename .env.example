# Auth.js v5 (NextAuth)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
AUTH_SECRET=

# AIOS single-user credentials.
# Generate the hash with:
#   node scripts/hash-password.mjs "<your password>"
# The script outputs the hash with $ characters already escaped as \$, which
# is required for Next.js's dotenv-expand parser. Paste the output verbatim.
AIOS_USER_USERNAME=nathan
AIOS_USER_PASSWORD_HASH=

# Module link-out URLs
DAY_DOCKET_APP_URL=https://dunsteel-docket-app.vercel.app
SWMS_TALLY_URL=https://tally.so/r/0QdBdZ
NOTION_SITE_DIARY_URL=
POWER_BI_URL=
NOTION_FORECAST_URL=https://www.notion.so/Project-Forecast-344172156ac58078a1d6c99c9b188d6d

# AIOS scope. Set to your primary project number (e.g. "411") to filter the
# dashboard, projects list, and dockets endpoint to that project only.
# Unset to see all projects.
AIOS_PRIMARY_PROJECT_NUMBER=

# Notion page ID for the Project Forecast doc (table page, kept a week
# ahead). Used by the upcoming forecast widget; not required for v1.
NOTION_FORECAST_PAGE_ID=

# Data sources (filled in as modules come online)
ANTHROPIC_API_KEY=
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
MONDAY_API_KEY=
MONDAY_WORKSHOP_BOARD_ID=18401143009
MONDAY_PO_BOARD_ID=5855005897
NOTION_API_KEY=
NOTION_SITE_DIARY_API_KEY=
NOTION_SITE_DIARY_DATABASE_ID=
NOTION_PROJECTS_DATABASE_ID=

# Notion database IDs (per-DB) for the AIOS surface widgets and Claude tools.
# Discover via `node --env-file=.env.local scripts/discover-notion-dbs.mjs`.
NOTION_PERFORMANCE_DIARY_DB=
NOTION_SUBCON_DIARY_DB=
NOTION_VOICE_MEMO_LOG_DB=
NOTION_DEFECTS_411_DB=
NOTION_GENERAL_NOTES_DB=
NOTION_PROJECTS_DB=
NOTION_TOOLBOX_TALKS_DB=

# MER (Monthly Earnings Report) Google Sheet
# Lives in Google Sheets, manually maintained twice a month by Nathan.
# Service account `aios-sheet-reader@...` must have Viewer access on the sheet.
GOOGLE_MER_SHEET_ID=
GOOGLE_MER_TAB=Sheet1
DUNSTEEL_BOT_TOKEN=
DUNSTEEL_CHAT_ID=
HARRY_CHAT_ID=
N8N_API_KEY_DUNSTEEL=
N8N_BASE_URL=
GOOGLE_SERVICE_ACCOUNT_KEY=
GOOGLE_DELIVERY_SHEET_ID=
GOOGLE_DELIVERY_SHEET_TAB=
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
